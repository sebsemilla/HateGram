{
  "expo": {
    "name": "feedpod",
    "slug": "feedpod",
    "version": "1.0.0",
    "scheme": "feedpod",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D0D0D"
    },
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "backgroundColor": "#0D0D0D" } },
